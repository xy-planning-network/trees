{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "node",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "lib": [
      "esnext",
      "dom"
    ],
    "paths": {
      "@/*": ["src/*"],
      "@heroicons/vue/outline": ["node_modules/@heroicons/vue/24/outline"],
      "@heroicons/vue/solid": ["node_modules/@heroicons/vue/24/solid"]
    },
    "types": [
      "node",
      "vue",
      "vite/client"
    ],
  },
  "exclude": [
    "dist",
    "types",
    "node_modules"
  ],
}
