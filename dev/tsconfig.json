{
  "extends": "../tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "./*": [
        "./*"
      ],
      "@/*": [
        "../src/*"
      ],
      "@heroicons/vue/outline": ["node_modules/@heroicons/vue/24/outline"],
      "@heroicons/vue/solid": ["node_modules/@heroicons/vue/24/solid"]
    }
  },
  "include": [
    "./**/*.md",
    "./**/*.ts",
    "./**/*.d.ts",
    "./**/*.tsx",
    "./**/*.vue",
    "../components.d.ts",
  ]
}
